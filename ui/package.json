  },
  "devDependencies": {
    "@types/node": "^24.10.13",
    "@typescript/native": "npm:typescript@^7.0.2",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vue/tsconfig": "^0.9.1",
    "sass": "^1.97.3",
    "typescript": "npm:@typescript/typescript6@^6.0.2",
    "unplugin-auto-import": "^21.0.0",
    "unplugin-vue-components": "^31.0.0",
    "vite": "^7.3.1",
    "vue-tsc": "^3.3.7"
  }
